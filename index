    function loadBaseFromText(totalTxt, disposalTxt) {
        baseRegistrations = processTotalFiles(totalTxt);
        baseDisposals = processDisposalFile(disposalTxt);
        renderPendingTable();
        let from = document.getElementById('fromDate').value;
        let to = document.getElementById('toDate').value;
        if(from && to) generateMPR(from, to);
        document.getElementById('dataStatus').innerHTML = "✅ Base data loaded";
    }

    function loadDefaultBase() {
        loadBaseFromText(DEFAULT_TOTAL, DEFAULT_DISPOSAL);
        document.getElementById('dataStatus').innerHTML = "📁 Default integrated data loaded";
    }

    async function loadFromUploadedFiles(totalFile, disposalFile) {
        try {
            const totalTxt = await totalFile.text();
            const dispTxt = await disposalFile.text();
            loadBaseFromText(totalTxt, dispTxt);
            document.getElementById('dataStatus').innerHTML = "✅ Custom files processed & loaded";
        } catch(e) { alert("Error reading files"); }
    }

    // ------------------------- EVENT LISTENERS -------------------------
    document.getElementById('addRegistrationBtn').addEventListener('click', addManualRegistration);
    document.getElementById('addDisposalBtn').addEventListener('click', addManualDisposal);
    document.getElementById('resetAllBtn').addEventListener('click', resetToBase);
    document.getElementById('refreshDataBtn').addEventListener('click', () => {
        const totalFile = document.getElementById('totalFileInput').files[0];
        const dispFile = document.getElementById('disposalFileInput').files[0];
        if(totalFile && dispFile) {
            loadFromUploadedFiles(totalFile, dispFile);
        } else {
            loadDefaultBase();
        }
        // also reset manual after loading base? keep manual separate? We clear manual entries after loading new base.
        manualRegistrations = [];
        manualDisposals.clear();
        renderPendingTable();
        let from = document.getElementById('fromDate').value;
        let to = document.getElementById('toDate').value;
        if(from && to) generateMPR(from, to);
    });
    document.getElementById('generateMprBtn').addEventListener('click', () => {
        let from = document.getElementById('fromDate').value;
        let to = document.getElementById('toDate').value;
        if(from && to) generateMPR(from, to);
        else alert("Select both dates");
    });
    // auto-update regYear when date picked
    document.getElementById('regDate').addEventListener('change', function() {
        let d = new Date(this.value);
        if(!isNaN(d.getTime())) document.getElementById('regYear').value = d.getFullYear();
        else document.getElementById('regYear').value = '';
    });
    // initial load
    loadDefaultBase();
    // ensure manual clears after base load flag
</script>
