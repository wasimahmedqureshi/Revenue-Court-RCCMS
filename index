<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>RCCMS Revenue Court Portal | Registrations & Disposals</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        }
        body {
            background: #eef2f7;
            margin: 0;
            padding: 20px;
            color: #1e2a3e;
        }
        .container {
            max-width: 1600px;
            margin: 0 auto;
        }
        .card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            padding: 1.5rem;
            margin-bottom: 2rem;
            transition: all 0.2s;
        }
        .card-header {
            font-size: 1.5rem;
            font-weight: 600;
            border-left: 5px solid #2c6e9e;
            padding-left: 1rem;
            margin-bottom: 1.2rem;
            color: #0f3b5c;
        }
        .badge {
            background: #eef2ff;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 500;
            color: #1e40af;
        }
        .form-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            align-items: flex-end;
            margin-top: 0.5rem;
        }
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
            min-width: 170px;
        }
        .form-group label {
            font-weight: 600;
            font-size: 0.8rem;
        }
        input, select {
            padding: 8px 12px;
            border-radius: 20px;
            border: 1px solid #cbd5e1;
            background: white;
            font-size: 0.85rem;
        }
        button {
            background: #1e4a76;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
            font-size: 0.85rem;
        }
        button:hover {
            background: #0f3a5c;
            transform: scale(0.98);
        }
        .btn-outline {
            background: white;
            border: 1px solid #1e4a76;
            color: #1e4a76;
        }
        .btn-outline:hover {
            background: #e6f0f9;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }
        th, td {
            border-bottom: 1px solid #e2e8f0;
            padding: 10px 8px;
            text-align: left;
        }
        th {
            background: #f1f5f9;
            font-weight: 600;
            position: sticky;
            top: 0;
        }
        .scrollable-table {
            overflow-x: auto;
            border-radius: 16px;
            max-height: 420px;
            overflow-y: auto;
        }
        .stats-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1.2rem;
            margin: 1.2rem 0;
        }
        .stat-card {
            background: #f1f5f9;
            border-radius: 24px;
            padding: 1rem 1.6rem;
            text-align: center;
            min-width: 140px;
        }
        .stat-number {
            font-size: 2rem;
            font-weight: 800;
            color: #0c4a6e;
        }
        .age-cats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
            gap: 12px;
            margin-top: 20px;
        }
        .age-item {
            background: #fef9e3;
            border-radius: 16px;
            padding: 10px;
            text-align: center;
            font-weight: 500;
        }
        .alert {
            background: #dbeafe;
            border-radius: 20px;
            padding: 8px 14px;
            font-size: 0.8rem;
            margin-top: 10px;
            display: inline-block;
        }
        hr {
            margin: 1rem 0;
        }
        footer {
            text-align: center;
            font-size: 0.75rem;
            color: #5b6e8c;
            margin-top: 2rem;
        }
        .flex-between {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }
        @media (max-width: 700px) {
            .card { padding: 1rem; }
            .form-group { min-width: 100%; }
        }
    </style>
</head>
<body>
<div class="container">
    <!-- Header -->
    <div class="card" style="background: linear-gradient(135deg, #eef2ff, #ffffff)">
        <h1 style="margin:0 0 6px 0;">🏛️ RCCMS Revenue Court Portal</h1>
        <p style="margin:0; color:#2c3e66;">Assistant Collector (Fastrack), Niwai — Pending Cases & MPR Dashboard</p>
        <p class="badge" style="margin-top: 8px;">⚡ Manual Registration + Disposal | Live Update</p>
    </div>

    <!-- File Upload Section (Base Data) -->
    <div class="card">
        <div class="flex-between">
            <div class="card-header">📂 Base Data Source</div>
            <button id="resetAllBtn" class="btn-outline" style="background:#ffeeee;">⟳ Reset to Base (clear manual entries)</button>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
            <div style="flex:1; background:#f8fafc; border-radius:1rem; padding:0.8rem;">
                <label>📄 Total Files (RRCMS Master)</label>
                <input type="file" id="totalFileInput" accept=".txt,.csv,text/plain">
                <div class="badge" style="margin-top:6px;">Default: embedded master data</div>
            </div>
            <div style="flex:1; background:#f8fafc; border-radius:1rem; padding:0.8rem;">
                <label>🗑️ Disposal Files</label>
                <input type="file" id="disposalFileInput" accept=".txt,.csv,text/plain">
                <div class="badge">Default: embedded disposal records</div>
            </div>
            <div style="display: flex; align-items: end; gap: 10px;">
                <button id="refreshDataBtn">⟳ Reload Base Files</button>
                <span class="badge" id="dataStatus">✅ Default base loaded</span>
            </div>
        </div>
        <p class="badge" style="background:#e6f7e6;">✓ Base data + manual registrations/disposals = complete live dataset.</p>
    </div>

    <!-- Manual Registration Form -->
    <div class="card">
        <div class="card-header">📝 Manual Registration (Add New Case File)</div>
        <div class="form-grid">
            <div class="form-group">
                <label>RRCMS No *</label>
                <input type="text" id="regRrcms" placeholder="e.g., 202605153200099 or 2025/101">
            </div>
            <div class="form-group">
                <label>Registration Date *</label>
                <input type="date" id="regDate">
            </div>
            <div class="form-group">
                <label>Dhara / Stream</label>
                <input type="text" id="regDhara" placeholder="188,53 / 212(02) etc">
            </div>
            <div class="form-group">
                <label>Reg Year (auto)</label>
                <input type="text" id="regYear" readonly style="background:#f3f4f6;">
            </div>
            <div class="form-group">
                <button id="addRegistrationBtn">➕ Add Registration</button>
            </div>
        </div>
        <div id="regMessage" class="alert" style="display:none;"></div>
    </div>

    <!-- Manual Disposal Form -->
    <div class="card">
        <div class="card-header">🗑️ Manual Disposal (Mark Case as Disposed)</div>
        <div class="form-grid">
            <div class="form-group">
                <label>RRCMS No *</label>
                <input type="text" id="disposeRrcms" placeholder="Existing RRCMS No">
            </div>
            <div class="form-group">
                <label>Disposal Date *</label>
                <input type="date" id="disposeDate">
            </div>
            <div class="form-group">
                <button id="addDisposalBtn">✅ Mark Disposed</button>
            </div>
        </div>
        <div id="disposeMessage" class="alert" style="display:none;"></div>
    </div>

    <!-- Pending Files List -->
    <div class="card">
        <div class="card-header">📋 Pending Cases (Not Disposed) — Live</div>
        <div class="scrollable-table">
            <table id="pendingTable">
                <thead>
                    <tr><th>S.No</th><th>RRCMS No</th><th>Registration Date</th><th>Dhara / Stream</th><th>Reg Year</th></tr>
                </thead>
                <tbody id="pendingTableBody">
                    <tr><td colspan="5">Loading data......</td></tr>
                </tbody>
             </table>
        </div>
        <div style="margin-top: 12px;"><span class="badge" id="pendingCountBadge">Pending: --</span></div>
    </div>

    <!-- MPR Report Generator -->
    <div class="card">
        <div class="card-header">📊 MPR Report (Misil Progress Report)</div>
        <div style="display: flex; flex-wrap: wrap; gap: 20px; align-items: flex-end; margin-bottom: 20px;">
            <div><label>📅 From Date: </label><input type="date" id="fromDate" value="2026-01-01"></div>
            <div><label>📅 To Date: </label><input type="date" id="toDate" value="2026-05-09"></div>
            <div><button id="generateMprBtn" class="btn">📈 Generate MPR Report</button></div>
        </div>
        <div id="mprResults">
            <div class="stats-grid" id="mprSummary"></div>
            <div id="ageBreakdown"></div>
        </div>
    </div>
    <footer>⚖️ Manual registrations/disposals stored in memory (session). 'Reset to Base' clears manual entries. Pending = Registered & not disposed.</footer>
</div>

<script>
    // ------------------------- GLOBAL DATA -------------------------
    let baseRegistrations = [];       // loaded from total files (default or uploaded)
    let baseDisposals = new Map();    // loaded from disposal files

    let manualRegistrations = [];      // user added registrations
    let manualDisposals = new Map();   // user added disposals (rrcms -> Date)

    // Helper: combine all data
    function getAllRegistrations() {
        return [...baseRegistrations, ...manualRegistrations];
    }
    function getAllDisposals() {
        const combined = new Map(baseDisposals);
        for (let [rrcms, dispDate] of manualDisposals.entries()) {
            combined.set(rrcms, dispDate);
        }
        return combined;
    }

    // ------------------------- UTILITIES -------------------------
    function parseDateFromString(dateStr) {
        if (!dateStr) return null;
        // try mm/dd/yyyy or yyyy-mm-dd
        let parts = dateStr.trim().split('/');
        if (parts.length === 3) {
            let month = parseInt(parts[0],10), day = parseInt(parts[1],10), year = parseInt(parts[2],10);
            if (!isNaN(month) && !isNaN(day) && !isNaN(year)) return new Date(year, month-1, day);
        }
        let d = new Date(dateStr);
        if (!isNaN(d.getTime())) return d;
        return null;
    }
    function formatDate(date) {
        if (!date || isNaN(date.getTime())) return "";
        return `${date.getMonth()+1}/${date.getDate()}/${date.getFullYear()}`;
    }

    // Process total files text (similar to original)
    function processTotalFiles(txt) {
        const lines = txt.split(/\r?\n/);
        const records = [];
        for(let line of lines){
            line = line.trim();
            if(!line || line.toLowerCase().includes("s.n.") || line.toLowerCase().includes("rrcms")) continue;
            let parts = line.split(/\s+/);
            if(parts.length < 3) continue;
            let rrcms = parts[1] ? parts[1].trim() : null;
            if(!rrcms || (!rrcms.includes('/') && !/^\d+$/.test(rrcms) && rrcms.length<4)) continue;
            let dateStr = parts[2];
            let regDateObj = parseDateFromString(dateStr);
            if(!regDateObj) continue;
            let dharaRaw = "";
            let regYear = null;
            for(let i=3;i<parts.length;i++){
                if(/^\d{4}$/.test(parts[i])) { regYear = parseInt(parts[i]); break; }
                dharaRaw += parts[i] + " ";
            }
            dharaRaw = dharaRaw.trim().replace(/\s+/g, ' ');
            if(!regYear && regDateObj) regYear = regDateObj.getFullYear();
            records.push({ rrcms: rrcms, regDateObj: regDateObj, dhara: dharaRaw || "-", regYear: regYear || regDateObj.getFullYear() });
        }
        return records;
    }
    function processDisposalFile(txt) {
        const map = new Map();
        const lines = txt.split(/\r?\n/);
        for(let line of lines){
            line = line.trim();
            if(!line || line.toLowerCase().includes("rrcms")) continue;
            let tokens = line.split(/\s+/);
            if(tokens.length < 2) continue;
            let rrcms = tokens[0];
            let lastToken = tokens[tokens.length-1];
            let dateObj = parseDateFromString(lastToken);
            if(dateObj && rrcms && !map.has(rrcms)){
                map.set(rrcms, dateObj);
            }
        }
        return map;
    }

    // ------------------------- RENDER PENDING TABLE -------------------------
    function renderPendingTable() {
        const allRegs = getAllRegistrations();
        const allDisposalsMap = getAllDisposals();
        const pending = allRegs.filter(reg => !allDisposalsMap.has(reg.rrcms));
        const tbody = document.getElementById('pendingTableBody');
        tbody.innerHTML = "";
        if(pending.length === 0){
            tbody.innerHTML = "<tr><td colspan='5'>No pending cases</td></tr>";
        } else {
            pending.forEach((rec, idx) => {
                let row = tbody.insertRow();
                row.insertCell(0).innerText = idx+1;
                row.insertCell(1).innerText = rec.rrcms;
                row.insertCell(2).innerText = formatDate(rec.regDateObj);
                row.insertCell(3).innerText = rec.dhara;
                row.insertCell(4).innerText = rec.regYear;
            });
        }
        document.getElementById('pendingCountBadge').innerHTML = `📌 Total Pending Cases: ${pending.length}`;
    }

    // ------------------------- MPR GENERATION -------------------------
    function getAgeCategory(regDate, asOnDate) {
        if(!regDate || !asOnDate) return "Unknown";
        const years = (asOnDate - regDate) / (1000*3600*24*365.25);
        if(years < 0.5) return "Upto 6 Months";
        if(years < 1) return "6 Months To 1 year";
        if(years < 2) return "1 To 2 Years";
        if(years < 3) return "2 To 3 Years";
        if(years < 5) return "3 To 5 Years";
        if(years < 10) return "5 To 10 Years";
        if(years < 20) return "10 To 20 Years";
        if(years < 30) return "20 To 30 Years";
        if(years < 40) return "30 To 40 Years";
        return "More Than 40 Years";
    }
    function generateMPR(fromDateStr, toDateStr) {
        const fromDate = new Date(fromDateStr);
        const toDate = new Date(toDateStr);
        if(isNaN(fromDate) || isNaN(toDate)) { alert("Invalid date range"); return; }
        const allRegs = getAllRegistrations();
        const allDisposalsMap = getAllDisposals();

        let initialPending = allRegs.filter(reg => {
            if(reg.regDateObj >= fromDate) return false;
            let disp = allDisposalsMap.get(reg.rrcms);
            return !disp || disp >= fromDate;
        }).length;

        let newRegistered = allRegs.filter(reg => reg.regDateObj >= fromDate && reg.regDateObj <= toDate).length;

        let totalDecided = 0;
        for(let [rrcms, dispDate] of allDisposalsMap.entries()) {
            if(dispDate >= fromDate && dispDate <= toDate) totalDecided++;
        }

        let pendingAsOn = allRegs.filter(reg => {
            if(reg.regDateObj > toDate) return false;
            let disp = allDisposalsMap.get(reg.rrcms);
            return !disp || disp > toDate;
        }).length;

        const pendingCases = allRegs.filter(reg => {
            if(reg.regDateObj > toDate) return false;
            let disp = allDisposalsMap.get(reg.rrcms);
            return !disp || disp > toDate;
        });
        const categories = ["Upto 6 Months","6 Months To 1 year","1 To 2 Years","2 To 3 Years","3 To 5 Years","5 To 10 Years","10 To 20 Years","20 To 30 Years","30 To 40 Years","More Than 40 Years"];
        let ageCount = new Array(categories.length).fill(0);
        pendingCases.forEach(p => {
            let cat = getAgeCategory(p.regDateObj, toDate);
            let idx = categories.indexOf(cat);
            if(idx !== -1) ageCount[idx]++;
        });

        document.getElementById('mprSummary').innerHTML = `
            <div class="stat-card"><div class="stat-number">${initialPending}</div><div>📌 Initial Pending<br><span style="font-size:12px">(as on ${fromDate.toLocaleDateString()})</span></div></div>
            <div class="stat-card"><div class="stat-number">${newRegistered}</div><div>➕ New Registered<br><span style="font-size:12px">${fromDate.toLocaleDateString()} - ${toDate.toLocaleDateString()}</span></div></div>
            <div class="stat-card"><div class="stat-number">${totalDecided}</div><div>✅ Total Decided</div></div>
            <div class="stat-card"><div class="stat-number">${pendingAsOn}</div><div>📂 Pending As On<br>${toDate.toLocaleDateString()}</div></div>
        `;
        let ageHtml = `<div style="margin-top:20px;"><strong>📊 Age-wise Pending Cases (as on ${toDate.toLocaleDateString()})</strong><div class="age-cats">`;
        categories.forEach((cat,i)=>{
            ageHtml += `<div class="age-item">${cat}<br><span style="font-size:1.6rem; font-weight:bold;">${ageCount[i]}</span></div>`;
        });
        ageHtml += `</div></div>`;
        document.getElementById('ageBreakdown').innerHTML = ageHtml;
    }

    // ------------------------- MANUAL ACTIONS -------------------------
    function showMessage(divId, msg, isError = false) {
        const div = document.getElementById(divId);
        div.style.display = "block";
        div.innerText = msg;
        div.style.background = isError ? "#fee2e2" : "#dcfce7";
        div.style.color = isError ? "#991b1b" : "#166534";
        setTimeout(() => { div.style.display = "none"; }, 3500);
    }

    function addManualRegistration() {
        let rrcms = document.getElementById('regRrcms').value.trim();
        let regDateStr = document.getElementById('regDate').value;
        let dhara = document.getElementById('regDhara').value.trim();
        if(!rrcms || !regDateStr) {
            showMessage('regMessage', "❌ RRCMS No and Registration Date are required", true);
            return;
        }
        let regDateObj = new Date(regDateStr);
        if(isNaN(regDateObj.getTime())){
            showMessage('regMessage', "❌ Invalid date", true);
            return;
        }
        const allRegs = getAllRegistrations();
        if(allRegs.some(reg => reg.rrcms === rrcms)) {
            showMessage('regMessage', `⚠️ RRCMS ${rrcms} already exists. Duplicate not allowed.`, true);
            return;
        }
        let regYear = regDateObj.getFullYear();
        document.getElementById('regYear').value = regYear;
        manualRegistrations.push({
            rrcms: rrcms,
            regDateObj: regDateObj,
            dhara: dhara || "-",
            regYear: regYear
        });
        document.getElementById('regRrcms').value = '';
        document.getElementById('regDate').value = '';
        document.getElementById('regDhara').value = '';
        document.getElementById('regYear').value = '';
        renderPendingTable();
        // refresh MPR after registration (if dates already set)
        let from = document.getElementById('fromDate').value;
        let to = document.getElementById('toDate').value;
        if(from && to) generateMPR(from, to);
        showMessage('regMessage', `✅ Registration added: ${rrcms}`, false);
    }

    function addManualDisposal() {
        let rrcms = document.getElementById('disposeRrcms').value.trim();
        let dispDateStr = document.getElementById('disposeDate').value;
        if(!rrcms || !dispDateStr) {
            showMessage('disposeMessage', "❌ RRCMS No and Disposal Date required", true);
            return;
        }
        let dispDateObj = new Date(dispDateStr);
        if(isNaN(dispDateObj.getTime())){
            showMessage('disposeMessage', "❌ Invalid disposal date", true);
            return;
        }
        const allRegs = getAllRegistrations();
        if(!allRegs.some(reg => reg.rrcms === rrcms)) {
            showMessage('disposeMessage', `❌ RRCMS ${rrcms} not found in registrations. Cannot dispose.`, true);
            return;
        }
        // set manual disposal (overwrites any previous manual or base? we respect manual as latest)
        manualDisposals.set(rrcms, dispDateObj);
        // if the same rrcms exists in baseDisposals we now have manual override (getAllDisposals will use manual)
        renderPendingTable();
        let from = document.getElementById('fromDate').value;
        let to = document.getElementById('toDate').value;
        if(from && to) generateMPR(from, to);
        showMessage('disposeMessage', `✅ Disposal recorded for ${rrcms} on ${formatDate(dispDateObj)}`, false);
        document.getElementById('disposeRrcms').value = '';
        document.getElementById('disposeDate').value = '';
    }

    function resetToBase() {
        manualRegistrations = [];
        manualDisposals.clear();
        renderPendingTable();
        let from = document.getElementById('fromDate').value;
        let to = document.getElementById('toDate').value;
        if(from && to) generateMPR(from, to);
        showMessage('regMessage', "🔄 Reset complete: all manual entries cleared.", false);
    }

    // ------------------------- LOAD BASE FILES (default or uploaded) -------------------------
    // Embedded default total files (partial but representative - will combine from given content)
